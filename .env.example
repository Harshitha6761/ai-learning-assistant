# Supabase (create project at https://supabase.com) – DB and storage only (no Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session (use a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production

# AI: use ONE of these. If both are set, Groq is used (free tier).
# Groq – FREE, recommended (https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key

# Google Gemini – optional (https://aistudio.google.com/apikey). Used only if GROQ_API_KEY is not set.
# GOOGLE_AI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash-lite

# Explore: real YouTube video results (optional). Get key: Google Cloud Console → YouTube Data API v3.
# YOUTUBE_API_KEY=your-youtube-api-key
